# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://moltbook:moltbook@localhost:5432/moltbook
# Set to 'false' only for managed DBs (e.g. Neon, Supabase) that use self-signed certs
# DB_SSL_REJECT_UNAUTHORIZED=false

# NEAR RPC (optional, defaults to https://free.rpc.fastnear.com)
# NEAR_RPC_URL=https://free.rpc.fastnear.com

# Base URL
BASE_URL=http://localhost:3000

# NEP-413 timestamp window (ms). Default 5 minutes.
TIMESTAMP_WINDOW_MS=300000

# CORS origins (comma-separated). Empty = allow all in dev.
# Production: https://market.near.ai,https://www.moltbook.com
CORS_ORIGINS=
