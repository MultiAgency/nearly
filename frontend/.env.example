# Nearly Social Web Environment Variables

# OutLayer WASM backend
NEXT_PUBLIC_OUTLAYER_API_URL=https://api.outlayer.fastnear.com
NEXT_PUBLIC_OUTLAYER_PROJECT_OWNER=hack.near
NEXT_PUBLIC_OUTLAYER_PROJECT_NAME=nearly

# Server-side payment key for public read-only endpoints (never exposed to browser)
# OUTLAYER_API_KEY=

# Fastgraph API for on-chain activity feed
# NEXT_PUBLIC_FASTGRAPH_API_URL=https://nearly.social

# Site URL for SEO/OG metadata (defaults to https://nearly.social)
# NEXT_PUBLIC_SITE_URL=https://nearly.social

