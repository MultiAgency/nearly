# Copy to .env. NEXT_PUBLIC_* vars are exposed to the browser.
NEXT_PUBLIC_OUTLAYER_API_URL=https://api.outlayer.fastnear.com
NEXT_PUBLIC_OUTLAYER_PROJECT_OWNER=hack.near
NEXT_PUBLIC_OUTLAYER_PROJECT_NAME=nearly
# NEXT_PUBLIC_SITE_URL=https://nearly.social

# FastData KV (defaults shown; override for staging/local)
# FASTDATA_KV_URL=https://kv.main.fastnear.com
# FASTDATA_NAMESPACE=contextual.near

# Pays for VRF WASM calls (required in production)
# OUTLAYER_PAYMENT_KEY=

# Admin identity + signing key for hide/unhide writes
# OUTLAYER_ADMIN_ACCOUNT=
# OUTLAYER_ADMIN_NEAR_KEY=

# NEP-413 claim freshness window in ms (default: 300000)
# CLAIM_FRESHNESS_MS=

# market.near.ai API (default: https://market.near.ai/v1)
# NEAR_MARKET_API_URL=
# API key for market.near.ai stats endpoint (required; returns 500 without it)
# NEAR_MARKET_API_KEY=

# Near FM API base (default: https://api.near.fm)
# NEARFM_API_URL=

# Agent keys for testing (never exposed to browser).
# These are raw OutLayer wallet keys — separate from SDK CLI
# credentials (NEARLY_WK_KEY / NEARLY_WK_ACCOUNT_ID).
# OUTLAYER_TEST_ACCOUNT=
# OUTLAYER_TEST_WALLET_KEY=
# Comma-separated wk_ pool for stress-sign.mjs (overrides OUTLAYER_TEST_WALLET_KEY)
# OUTLAYER_WALLET_KEYS=

# ── Scripts & E2E ─────────────────────────────────────
# API base URL for smoke.sh, playwright, and ad-hoc test scripts
# NEARLY_API=https://nearly.social/api/v1
#
# Gate for SDK register integration test (burns a real trial wallet; set to 1)
# NEARLY_REGISTER_INTEGRATION=
