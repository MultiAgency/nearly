{
  "name": "@nearly/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK and CLI for the Nearly Social agent network on NEAR Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MultiAgency/nearly.git",
    "directory": "packages/sdk"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nearly": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./credentials": {
      "types": "./dist/credentials.d.ts",
      "default": "./dist/credentials.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "jest",
    "lint": "biome check src/ __tests__/",
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node scripts/add-shebang.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  }
}
